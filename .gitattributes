# Normalize line endings so a checkout behaves identically on macOS and
# Windows (core.autocrlf on Windows otherwise leaves the working tree CRLF).
* text=auto

# Source and config: always LF on disk.
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.mts text eol=lf
*.cts text eol=lf
*.js text eol=lf
*.cjs text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.css text eol=lf
*.html text eol=lf
*.sh text eol=lf
*.mdc text eol=lf

# Windows-native scripts need CRLF.
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binaries: never touch.
*.png binary
*.ico binary
*.icns binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.woff binary
*.woff2 binary
*.sqlite binary
